{
  "location": "${LOCATION}",
  "identity": {
    "type": "UserAssigned",
    "userAssignedIdentities": { "${LOGICAPP_IDENTITY_ID}": {} }
  },
  "properties": {
    "definition": {
      "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
      "contentVersion": "1.0.0.0",
      "parameters": {
        "ACS_EMAIL_URI":     { "type": "string", "defaultValue": "" },
        "LA_IDENTITY_ID":    { "type": "string", "defaultValue": "" },
        "ACS_SENDER":        { "type": "string", "defaultValue": "" },
        "DIGEST_RECIPIENTS": { "type": "string", "defaultValue": "[]" },
        "HQ_RECIPIENTS":     { "type": "string", "defaultValue": "[]" },
        "DASHBOARD_URL":     { "type": "string", "defaultValue": "" }
      },
      "triggers": {
        "Recurrence_0900KST": {
          "type": "Recurrence",
          "recurrence": {
            "frequency": "Day",
            "interval": 1,
            "schedule": { "hours": ["0"], "minutes": [0] },
            "timeZone": "UTC"
          }
        }
      },
      "actions": {
        "HTTP_Funnel": {
          "type": "Http",
          "inputs": {
            "method": "GET",
            "uri": "@{concat(parameters('DASHBOARD_URL'), '/dashboard/cascade/funnel?days=1')}"
          }
        },
        "Check_RejectedCount": {
          "type": "If",
          "runAfter": { "HTTP_Funnel": ["Succeeded", "Failed"] },
          "expression": {
            "and": [
              { "greater": [ "@coalesce(body('HTTP_Funnel')?['rejected'], 0)", 0 ] }
            ]
          },
          "actions": {
            "HTTP_RejectedItems": {
              "type": "Http",
              "inputs": {
                "method": "GET",
                "uri": "@{concat(parameters('DASHBOARD_URL'), '/dashboard/decision/plan-daily/', formatDateTime(convertTimeZone(utcNow(), 'UTC', 'Korea Standard Time'), 'yyyy-MM-dd'), '/items?status=REJECTED&page_size=50')}"
              }
            },
            "Send_RejectionAlert": {
              "type": "Http",
              "runAfter": { "HTTP_RejectedItems": ["Succeeded", "Failed"] },
              "operationOptions": "DisableAsyncPattern",
              "inputs": {
                "method": "POST",
                "uri": "@parameters('ACS_EMAIL_URI')",
                "authentication": {
                  "type": "ManagedServiceIdentity",
                  "identity": "@parameters('LA_IDENTITY_ID')",
                  "audience": "https://communication.azure.com"
                },
                "body": {
                  "senderAddress": "@parameters('ACS_SENDER')",
                  "recipients": { "to": "@json(parameters('HQ_RECIPIENTS'))" },
                  "content": {
                    "subject": "[승인거부] @{formatDateTime(convertTimeZone(utcNow(), 'UTC', 'Korea Standard Time'), 'yyyy-MM-dd')} 거부 @{coalesce(body('HTTP_Funnel')?['rejected'], 0)}건 — 지점·물류센터 사유 확인 필요",
                    "html": "<h2 style=\"color:#d93025;\">[승인거부] 사유 확인 요청</h2><p>오늘 발주 계획 중 <strong>@{coalesce(body('HTTP_Funnel')?['rejected'], 0)}건</strong>의 승인 거부가 발생했습니다.</p><p>거부한 지점 또는 물류센터와 거부 사유를 확인하고 조치해 주세요.</p><h3>당일 현황</h3><table border=\"1\" cellpadding=\"8\" cellspacing=\"0\" style=\"border-collapse:collapse;font-size:14px;\"><thead style=\"background:#f1f3f4;\"><tr><th>상태</th><th>건수</th></tr></thead><tbody><tr><td>승인 완료</td><td>@{coalesce(body('HTTP_Funnel')?['approved'], 0)}건</td></tr><tr style=\"color:#d93025;\"><td><strong>거부</strong></td><td><strong>@{coalesce(body('HTTP_Funnel')?['rejected'], 0)}건</strong></td></tr><tr><td>대기 중</td><td>@{coalesce(body('HTTP_Funnel')?['pending'], 0)}건</td></tr><tr><td>실행 완료</td><td>@{coalesce(body('HTTP_Funnel')?['executed'], 0)}건</td></tr></tbody></table><br/><p><a href=\"@{parameters('DASHBOARD_URL')}\" style=\"background:#d93025;color:#fff;padding:12px 24px;text-decoration:none;border-radius:4px;font-weight:bold;\">대시보드에서 거부 내역 확인하기</a></p><hr/><p style=\"font-size:12px;color:#666;\">본 메일은 BookFlow 시스템에서 자동 발송되었습니다.</p>"
                  },
                  "importance": "high"
                }
              }
            }
          },
          "else": {
            "actions": {
              "Check_HasApproved": {
                "type": "If",
                "expression": {
                  "and": [
                    { "greater": [ "@add(coalesce(body('HTTP_Funnel')?['approved'], 0), coalesce(body('HTTP_Funnel')?['executed'], 0))", 0 ] }
                  ]
                },
                "actions": {
                  "Send_FinalConfirmation": {
                    "type": "Http",
                    "operationOptions": "DisableAsyncPattern",
                    "inputs": {
                      "method": "POST",
                      "uri": "@parameters('ACS_EMAIL_URI')",
                      "authentication": {
                        "type": "ManagedServiceIdentity",
                        "identity": "@parameters('LA_IDENTITY_ID')",
                        "audience": "https://communication.azure.com"
                      },
                      "body": {
                        "senderAddress": "@parameters('ACS_SENDER')",
                        "recipients": { "to": "@json(parameters('DIGEST_RECIPIENTS'))" },
                        "content": {
                          "subject": "[최종확인요청] @{formatDateTime(convertTimeZone(utcNow(), 'UTC', 'Korea Standard Time'), 'yyyy-MM-dd')} 발주 계획 승인 완료 — 최종 계획 검토 요청",
                          "html": "<h2 style=\"color:#188038;\">[최종확인요청] 발주 계획 승인 완료</h2><p>오늘 발주 계획의 담당자 승인이 완료되었습니다. 최종 계획을 검토하고 운송 일정을 확인해 주세요.</p><h3>당일 현황</h3><table border=\"1\" cellpadding=\"8\" cellspacing=\"0\" style=\"border-collapse:collapse;font-size:14px;\"><thead style=\"background:#f1f3f4;\"><tr><th>상태</th><th>건수</th></tr></thead><tbody><tr style=\"color:#188038;\"><td><strong>승인 완료</strong></td><td><strong>@{coalesce(body('HTTP_Funnel')?['approved'], 0)}건</strong></td></tr><tr><td>실행 완료</td><td>@{coalesce(body('HTTP_Funnel')?['executed'], 0)}건</td></tr><tr><td>대기 중</td><td>@{coalesce(body('HTTP_Funnel')?['pending'], 0)}건</td></tr></tbody></table><br/><p><a href=\"@{parameters('DASHBOARD_URL')}\" style=\"background:#188038;color:#fff;padding:12px 24px;text-decoration:none;border-radius:4px;font-weight:bold;\">대시보드에서 최종 계획 확인하기</a></p><hr/><p style=\"font-size:12px;color:#666;\">본 메일은 BookFlow 시스템에서 자동 발송되었습니다.</p>"
                        },
                        "importance": "normal"
                      }
                    }
                  }
                },
                "else": {
                  "actions": {
                    "Send_DailyDigest": {
                      "type": "Http",
                      "operationOptions": "DisableAsyncPattern",
                      "inputs": {
                        "method": "POST",
                        "uri": "@parameters('ACS_EMAIL_URI')",
                        "authentication": {
                          "type": "ManagedServiceIdentity",
                          "identity": "@parameters('LA_IDENTITY_ID')",
                          "audience": "https://communication.azure.com"
                        },
                        "body": {
                          "senderAddress": "@parameters('ACS_SENDER')",
                          "recipients": { "to": "@json(parameters('DIGEST_RECIPIENTS'))" },
                          "content": {
                            "subject": "[일일현황] @{formatDateTime(convertTimeZone(utcNow(), 'UTC', 'Korea Standard Time'), 'yyyy-MM-dd')} BookFlow 발주 현황",
                            "html": "<h2>BookFlow 일일 현황</h2><p>오늘 처리된 발주 건이 없습니다.</p><h3>당일 현황</h3><table border=\"1\" cellpadding=\"8\" cellspacing=\"0\" style=\"border-collapse:collapse;font-size:14px;\"><thead style=\"background:#f1f3f4;\"><tr><th>상태</th><th>건수</th></tr></thead><tbody><tr><td>승인 완료</td><td>@{coalesce(body('HTTP_Funnel')?['approved'], 0)}건</td></tr><tr><td>실행 완료</td><td>@{coalesce(body('HTTP_Funnel')?['executed'], 0)}건</td></tr><tr><td>대기 중</td><td>@{coalesce(body('HTTP_Funnel')?['pending'], 0)}건</td></tr><tr><td>거부</td><td>@{coalesce(body('HTTP_Funnel')?['rejected'], 0)}건</td></tr></tbody></table><br/><p><a href=\"@{parameters('DASHBOARD_URL')}\" style=\"background:#1a73e8;color:#fff;padding:12px 24px;text-decoration:none;border-radius:4px;\">BookFlow 대시보드 바로가기</a></p>"
                          },
                          "importance": "normal"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "parameters": {
      "ACS_EMAIL_URI":     { "value": "${ACS_EMAIL_URI}" },
      "LA_IDENTITY_ID":    { "value": "${LOGICAPP_IDENTITY_ID}" },
      "ACS_SENDER":        { "value": "${ACS_SENDER}" },
      "DIGEST_RECIPIENTS": { "value": "[{\"address\":\"redfox@yonsei.ac.kr\",\"displayName\":\"본사\"},{\"address\":\"rladudgjs0427@gmail.com\",\"displayName\":\"물류\"},{\"address\":\"woohek00@gmail.com\",\"displayName\":\"지점\"}]" },
      "HQ_RECIPIENTS":     { "value": "[{\"address\":\"redfox@yonsei.ac.kr\",\"displayName\":\"본사/경영진\"}]" },
      "DASHBOARD_URL":     { "value": "${DASHBOARD_URL}" }
    }
  }
}
