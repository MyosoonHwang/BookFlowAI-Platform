{
  "definition": {
    "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
    "contentVersion": "1.0.0.0",
    "triggers": {
      "manual": {
        "type": "Request",
        "kind": "Http",
        "inputs": {
          "schema": {
            "type": "object",
            "properties": {
              "event_type": { "type": "string" },
              "severity":   { "type": "string" },
              "payload":    { "type": "object" },
              "recipients": { "type": "array" }
            },
            "required": ["event_type", "severity", "payload", "recipients"]
          }
        }
      }
    },
    "actions": {
      "Switch_EventType": {
        "type": "Switch",
        "expression": "@triggerBody()?['event_type']",
        "cases": {
          "DailyPlanFinalized": {
            "case": "DailyPlanFinalized",
            "actions": {
              "Email_DailyPlanFinalized": {
                "type": "Http",
                "operationOptions": "DisableAsyncPattern",
                "inputs": {
                  "method": "POST",
                  "uri": "@appsetting('ACS_EMAIL_URI')",
                  "authentication": {
                    "type": "ManagedServiceIdentity",
                    "identity": "@appsetting('LA_IDENTITY_ID')",
                    "audience": "https://communication.azure.com"
                  },
                  "body": {
                    "senderAddress": "@appsetting('ACS_SENDER')",
                    "recipients": { "to": "@triggerBody()?['recipients']" },
                    "content": {
                      "subject": "[최종확정] 의사결정 완료 · 운송 시작 가능",
                      "html": "<p>처리해야 할 의사결정이 모두 완료됐습니다 — 운송 시작 가능 상태.</p>"
                    },
                    "importance": "normal"
                  }
                }
              }
            }
          },
          "SpikeUrgent": {
            "case": "SpikeUrgent",
            "actions": {
              "Email_SpikeUrgent": {
                "type": "Http",
                "operationOptions": "DisableAsyncPattern",
                "inputs": {
                  "method": "POST",
                  "uri": "@appsetting('ACS_EMAIL_URI')",
                  "authentication": {
                    "type": "ManagedServiceIdentity",
                    "identity": "@appsetting('LA_IDENTITY_ID')",
                    "audience": "https://communication.azure.com"
                  },
                  "body": {
                    "senderAddress": "@appsetting('ACS_SENDER')",
                    "recipients": { "to": "@triggerBody()?['recipients']" },
                    "content": {
                      "subject": "[긴급] SNS 화제 도서 감지",
                      "html": "<p>SNS 화제 도서가 감지되었습니다. 24h 내 폭증 매출 가능성.</p>"
                    },
                    "importance": "high"
                  }
                }
              }
            }
          }
        },
        "default": { "actions": {} }
      },
      "Response": {
        "type": "Response",
        "runAfter": {
          "Switch_EventType": ["Succeeded", "Failed", "Skipped", "TimedOut"]
        },
        "inputs": {
          "statusCode": 200,
          "body": { "result": "ok" }
        }
      }
    }
  },
  "kind": "Stateful"
}
